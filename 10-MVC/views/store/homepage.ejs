<%- include('../partials/head')%>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800">
    <%- include('../partials/nav')%>
      <main class="mx-auto flex min-h-[calc(100vh-73px)] w-full max-w-6xl flex-col justify-center px-6 py-20">
        <div class="mx-auto max-w-3xl text-center">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-red-500">Welcome</p>
          <h2 class="max-w-2xl text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
            Find a simple, clean place to start your next stay.
          </h2>
          <h2 class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">
            Here below is your added homes.
          </h2>
        </div>

        <section class="mt-10 w-full">
          <div
            class="mb-6 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <div>
              <p class="text-sm font-medium text-slate-500">Your collection</p>
              <h3 class="text-lg font-semibold text-slate-900">
                <%= registeredHomes.length %> home<%= registeredHomes.length===1 ? '' : 's' %> ready to welcome guests
              </h3>
            </div>
            <span class="rounded-full bg-red-50 px-3 py-1 text-sm font-semibold text-red-600">Fresh listings</span>
          </div>

          <% if (registeredHomes.length===0) { %>
            <div class="rounded-2xl border border-dashed border-slate-300 bg-white/80 px-8 py-12 text-center shadow-sm">
              <p class="text-lg font-semibold text-slate-700">No homes added yet</p>
              <p class="mt-2 text-sm text-slate-500">Start by adding your first beautiful stay.</p>
            </div>
            <% } else { %>
              <ul class="grid w-full gap-3 sm:grid-cols-2 lg:grid-cols-3">
                <% registeredHomes.forEach((home, index)=> { %>
                  <li
                    class="group overflow-hidden rounded-2xl border border-slate-200 bg-white text-left shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                    <% if (home.image) { %>
                      <div class="aspect-4/3 overflow-hidden bg-slate-100">
                        <img src="<%= home.image %>" alt="<%= home.houseName %>"
                          class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                          loading="lazy" referrerpolicy="no-referrer" />
                      </div>
                      <% } else { %>
                        <div class="aspect-16/10 bg-linear-to-r from-rose-100 via-red-50 to-orange-100"></div>
                        <% } %>

                          <div class="p-3">
                            <div class="flex items-start justify-between gap-3">
                              <div>
                                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-red-500">Listing <%=
                                    index + 1 %>
                                </p>
                                <h3 class="mt-1 text-lg font-semibold tracking-tight text-slate-900">
                                  <%= home.houseName %>
                                </h3>
                              </div>
                              <span
                                class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Available</span>
                            </div>

                            <div class="mt-3 grid gap-2 text-sm sm:grid-cols-3">
                              <div class="rounded-xl bg-slate-50 px-2.5 py-2">
                                <p class="text-slate-500">Price</p>
                                <p class="mt-0.5 font-semibold text-slate-900">
                                  <%= home.price %>
                                </p>
                              </div>
                              <div class="rounded-xl bg-slate-50 px-2.5 py-2">
                                <p class="text-slate-500">Date</p>
                                <p class="mt-0.5 font-semibold text-slate-900">
                                  <%= home.date %>
                                </p>
                              </div>
                              <div class="rounded-xl bg-slate-50 px-2.5 py-2">
                                <p class="text-slate-500">Location</p>
                                <p class="mt-0.5 font-semibold text-slate-900">
                                  <%= home.location %>
                                </p>
                              </div>
                            </div>

                            <p class="mt-2.5 text-sm leading-6 text-slate-600">
                              A warm and welcoming home that is ready for your next guest experience.
                            </p>

                            <div class="mt-3 flex items-center justify-between text-sm text-slate-500">
                              <span class="rounded-full bg-slate-100 px-3 py-1">Guest favorite</span>
                              <span class="font-medium text-slate-700">View details</span>
                            </div>
                          </div>
                  </li>
                  <% }) %>
              </ul>
              <% } %>
        </section>

        <a href="/host/add-home"
          class="mt-8 inline-flex items-center justify-center rounded-xl bg-red-500 px-6 py-3 font-semibold text-white shadow-sm transition hover:bg-red-600 hover:shadow-md">
          Add Home
        </a>
      </main>
  </body>

  </html>