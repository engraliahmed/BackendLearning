<%- include('../partials/head')%>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800">
    <%- include('../partials/nav')%>

      <main class="mx-auto max-w-5xl px-6 py-16">
        <form action="/host/add-home" method="POST"
          class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-5">
          <div class="space-y-4">
            <div>
              <label for="houseName" class="mb-2 block text-sm font-medium text-slate-700">House name</label>
              <input id="houseName" type="text" name="houseName" placeholder="Enter the name of your house"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition placeholder:text-slate-400 focus:border-red-400 focus:ring-2 focus:ring-red-100" />
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="price" class="mb-2 block text-sm font-medium text-slate-700">Price</label>
                <input id="price" type="number" name="price" placeholder="Enter price"
                  class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition placeholder:text-slate-400 focus:border-red-400 focus:ring-2 focus:ring-red-100" />
              </div>
              <div>
                <label for="date" class="mb-2 block text-sm font-medium text-slate-700">Available date</label>
                <input id="date" type="date" name="date"
                  class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-red-400 focus:ring-2 focus:ring-red-100" />
              </div>
            </div>

            <div>
              <label for="location" class="mb-2 block text-sm font-medium text-slate-700">Location</label>
              <input id="location" type="text" name="location" placeholder="Enter the city or address"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition placeholder:text-slate-400 focus:border-red-400 focus:ring-2 focus:ring-red-100" />
            </div>

            <div>
              <label for="image" class="mb-2 block text-sm font-medium text-slate-700">Image link</label>
              <input id="image" type="url" name="image" placeholder="Paste a Google image URL"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition placeholder:text-slate-400 focus:border-red-400 focus:ring-2 focus:ring-red-100" />
            </div>
          </div>
          <button type="submit"
            class="inline-flex rounded-xl bg-red-500 px-5 py-3 font-semibold text-white transition hover:bg-red-600">
            Save Home
          </button>
        </form>
      </main>
  </body>

  </html>